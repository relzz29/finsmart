# ── Server ────────────────────────────────────────────────────────
PORT=5000

# ── Database MySQL (XAMPP) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=finsmart_db

# ── JWT ───────────────────────────────────────────────────────────
# WAJIB DIGANTI dengan string acak minimal 64 karakter sebelum production!
# Generate di: https://generate-secret.vercel.app/64
JWT_SECRET=GANTI_INI_DENGAN_SECRET_PANJANG_DAN_ACAK_MIN_64_KARAKTER_SEBELUM_PRODUCTION
JWT_EXPIRES_IN=7d

# ── CORS (URL front-end Vite) ─────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Front-end: URL API (dibaca Vite) ─────────────────────────────
VITE_API_URL=http://localhost:5000/v1

# ── Admin Invite Code (WAJIB DIGANTI sebelum production!) ─────────
# Kode rahasia yang dibutuhkan untuk mendaftar sebagai admin
ADMIN_INVITE_CODE=GANTI_KODE_ADMIN_RAHASIA_INI
